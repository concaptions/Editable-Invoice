# ---- n8n backend (server-side only; never exposed to the browser) ----
N8N_BASE_URL=https://primary-production-37b78.up.railway.app
N8N_PO_SEARCH_PATH=/webhook/po-search
N8N_PO_GET_PATH=/webhook/po-get
N8N_PO_APPROVE_PATH=/webhook/po-approve

# Optional shared secret. If set, sent to n8n as the `x-po-secret` header on every call.
N8N_SHARED_SECRET=

# ---- App auth ----
# The founder's login passcode.
APP_PASSCODE=

# Random string used to sign the session cookie (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
