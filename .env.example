# ---- Google Sheets (server-side only; never exposed to the browser) ----
# Spreadsheet that holds the Submissions tab.
SHEET_ID=1BLGlj9u0iAtdvqBgfxv9YE4HwvBP5YUV0C8DA8OqF_E
# Tab/worksheet name to read & write.
SHEET_TAB=Submissions
# Full service-account key JSON, as ONE line. The service-account email
# (client_email) must be shared on the sheet as an Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Product catalog (a Google Sheet, server-side only) ----
# Spreadsheet ID of the catalog workbook (~700 rows). Share it with the same
# service-account client_email (Viewer is enough).
CATALOG_SHEET_ID=
# The catalog tab, identified by its gid (the number after #gid= in the URL).
CATALOG_SHEET_GID=
# Optional: identify the catalog tab by name instead of gid.
# CATALOG_SHEET_TAB=

# ---- App auth ----
# The founder's login passcode.
APP_PASSCODE=

# Random string used to sign the session cookie (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# ---- Vendor payout service (single write path for payout details) ----
# The app never writes payout/bank details to the sheet directly. Instead it
# POSTs the full payout object (+ vendor/submission ids) to this external
# service, which persists to the master sheet and mirrors to GoHighLevel.
# Leave BLANK until the real endpoint is ready: the /api/po/payout route then
# responds `notConfigured` and the editor keeps the typed values (never lost).
PAYOUT_API_URL=
# Auth secret sent as the `x-payout-secret` request header. Never logged.
PAYOUT_API_SECRET=
